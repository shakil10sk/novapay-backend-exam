# NovaPay Environment Configuration
NODE_ENV=development
PORT=3000

# Master encryption key (32 bytes hex for AES-256)
ENCRYPTION_KEY=2b7e151628aed2a6abf7158809cf4f3c2b7e151628aed2a6abf7158809cf4f3c

# Account Service DB
ACCOUNT_DB_HOST=localhost
ACCOUNT_DB_PORT=5433
ACCOUNT_DB_USER=root
ACCOUNT_DB_PASS=password
ACCOUNT_DB_NAME=novapay_account

# Ledger Service DB
LEDGER_DB_HOST=localhost
LEDGER_DB_PORT=5434
LEDGER_DB_USER=root
LEDGER_DB_PASS=password
LEDGER_DB_NAME=novapay_ledger

# Transaction Service DB
TRANSACTION_DB_HOST=localhost
TRANSACTION_DB_PORT=5435
TRANSACTION_DB_USER=root
TRANSACTION_DB_PASS=password
TRANSACTION_DB_NAME=novapay_txn

# FX Service DB
FX_DB_HOST=localhost
FX_DB_PORT=5436
FX_DB_USER=root
FX_DB_PASS=password
FX_DB_NAME=novapay_fx

# Payroll Service DB
PAYROLL_DB_HOST=localhost
PAYROLL_DB_PORT=5437
PAYROLL_DB_USER=root
PAYROLL_DB_PASS=password
PAYROLL_DB_NAME=novapay_payroll

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Jaeger (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Mock FX Provider (set to 'down' to simulate outage)
FX_PROVIDER_STATUS=up

# Idempotency key TTL in hours
IDEMPOTENCY_TTL_HOURS=24
